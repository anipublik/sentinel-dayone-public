# Sentinel Day One - environment config
# Copy to .env and fill in. Never commit .env.

# ─── catalog source (pick one) ──────────────────────────────────────────────
CATALOG_SOURCE=workday

# Workday
WORKDAY_TENANT_URL=https://example.workday.com
WORKDAY_CLIENT_ID=
WORKDAY_CLIENT_SECRET=

# ServiceNow (uncomment if CATALOG_SOURCE=servicenow)
# SNOW_INSTANCE_URL=https://example.service-now.com
# SNOW_USERNAME=
# SNOW_PASSWORD=

# ─── neo4j ──────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=sentinel-dev

# ─── llm + embeddings ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-large
# EMBEDDING_PROVIDER=local   # optional; auto-fallback when OPENAI_API_KEY is unset

# ─── ingestion connectors ───────────────────────────────────────────────────
GITHUB_ORG=
GITHUB_TOKEN=

SLACK_BOT_TOKEN=

LINEAR_API_KEY=

CONFLUENCE_URL=
CONFLUENCE_USER=
CONFLUENCE_API_TOKEN=

# ─── buddy digest (optional) ────────────────────────────────────────────────
# SLACK_BUDDY_WEBHOOK_URL=
# SLACK_WEBHOOK_URL=
# SLACK_BUDDY_CHANNEL=

# ─── local demo ─────────────────────────────────────────────────────────────
# CATALOG_SOURCE=mock

# ─── provisioning targets ───────────────────────────────────────────────────
VAULT_ADDR=
VAULT_TOKEN=

KUBECONFIG_BUCKET=s3://sentinel-kubeconfigs
